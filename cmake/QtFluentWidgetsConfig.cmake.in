@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
set(_QTFLUENT_PACKAGE_PREFIX_DIR "${PACKAGE_PREFIX_DIR}")
set(_QTFLUENT_INSTALL_BINDIR "@PACKAGE_CMAKE_INSTALL_BINDIR@")
set(_QTFLUENT_INSTALL_LIBDIR "@PACKAGE_CMAKE_INSTALL_LIBDIR@")
find_dependency(@QT_PACKAGE@ COMPONENTS Widgets Svg)
set(PACKAGE_PREFIX_DIR "${_QTFLUENT_PACKAGE_PREFIX_DIR}")

if(NOT TARGET rlottie::rlottie)
    add_library(rlottie::rlottie SHARED IMPORTED)
    set(_QTFLUENT_RLOTTIE_RUNTIME_NAME "@CMAKE_SHARED_LIBRARY_PREFIX@rlottie@CMAKE_SHARED_LIBRARY_SUFFIX@")
    set(_QTFLUENT_RLOTTIE_IMPORT_NAME "@CMAKE_IMPORT_LIBRARY_PREFIX@rlottie@CMAKE_IMPORT_LIBRARY_SUFFIX@")

    if(WIN32)
        set_target_properties(rlottie::rlottie PROPERTIES
            IMPORTED_LOCATION "${_QTFLUENT_INSTALL_BINDIR}/${_QTFLUENT_RLOTTIE_RUNTIME_NAME}"
            IMPORTED_IMPLIB "${_QTFLUENT_INSTALL_LIBDIR}/${_QTFLUENT_RLOTTIE_IMPORT_NAME}"
        )
    else()
        set_target_properties(rlottie::rlottie PROPERTIES
            IMPORTED_LOCATION "${_QTFLUENT_INSTALL_LIBDIR}/${_QTFLUENT_RLOTTIE_RUNTIME_NAME}"
        )
    endif()
endif()

include("${CMAKE_CURRENT_LIST_DIR}/QtFluentWidgetsTargets.cmake")
